# Shared Super-Linter configuration — the single source of truth read by BOTH the
# CI workflow (.github/workflows/super-linter.yml) and the local runner
# (scripts/dev/run-super-linter.cs), so local and CI lint can never drift.
#
# Only static settings live here. Dynamic/CI-only values stay in the workflow:
# GITHUB_TOKEN, DEFAULT_BRANCH, and the MULTI_STATUS / summary-comment reporting
# toggles. The local runner supplies its own RUN_LOCAL + DEFAULT_BRANCH.
#
# Include-only: enabling any VALIDATE_* defaults the rest to false. These are the
# languages we actually have plus hygiene + secrets. C#/dotnet is covered by
# build.yml + CodeQL + Sonar, so it is intentionally absent here.
VALIDATE_ALL_CODEBASE=false
VALIDATE_MARKDOWN=true
VALIDATE_YAML=true
VALIDATE_GITHUB_ACTIONS=true
VALIDATE_JSON=true
VALIDATE_BASH=true
VALIDATE_EDITORCONFIG=true
VALIDATE_GITLEAKS=true
LINTER_RULES_PATH=.github/linters
MARKDOWN_CONFIG_FILE=.markdownlint.yml
# Lint the hand-written hooks (.husky/pre-commit, commit-msg, pre-push); skip only
# the Husky.Net-generated internals under .husky/_/.
FILTER_REGEX_EXCLUDE=(^|/)\.husky/_/
