#!/bin/sh
# shellcheck source=/dev/null  # husky.sh is generated in .husky/_/ at install time
. "$(dirname "$0")/_/husky.sh"

## husky task runner examples -------------------
## Note : for local installation use 'dotnet' prefix. e.g. 'dotnet husky'

## run all tasks
#husky run

### run all tasks with group: 'group-name'
#husky run --group group-name

## run task with name: 'task-name'
#husky run --name task-name

## pass hook arguments to task
#husky run --args "$1" "$2"

## or put your custom commands -------------------
#echo 'Husky.Net is awesome!'

# Word-splitting is intentional: each staged path becomes a separate argument.
# `set -f` disables glob expansion so a path containing *, ?, or [ ] is passed
# literally rather than expanded against the working tree.
set -f
# shellcheck disable=SC2046
dotnet run scripts/git/check-commit-message.cs -- "$1" $(git diff --cached --name-only)
